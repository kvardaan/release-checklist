# Database URL for PostgreSQL (only needed if MOCK is not true)
# Example for Supabase: postgresql://username:password@db.xxxxx.supabase.co:5432/postgres
# Example for local: postgresql://user:password@localhost:5432/release_checklist
DATABASE_URL="postgresql://user:password@localhost:5432/release_checklist"

# Set to true to use JSON file-based mock storage instead of a database
# This is useful for local development and testing without needing PostgreSQL
# When true, data will be stored in .data/releases.json
MOCK="false"
